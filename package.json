{
  "name": "@ecssc/commitlint-config",
  "version": "0.0.4",
  "description": "Shared commitlint config for ECSSC projects",
  "license": "MIT",
  "author": "Edward Coleridge Smith <edcoleridgesmith@gmail.com>",
  "type": "module",
  "exports": "./src/index.mjs",
  "overrides": {
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "brace-expansion@1": "^1.1.13"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ecssc/commitlint-config.git"
  },
  "scripts": {
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "release": "release-it"
  },
  "lint-staged": {
    "*.{mjs,cjs,js,json}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "@commitlint/cli": "^20.0.0"
  },
  "dependencies": {
    "@commitlint/config-conventional": "^20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@ecssc/eslint-config": "^1.0.0",
    "@ecssc/prettier-config": "^0.1.0",
    "@ecssc/release-it-config": "^1.0.2",
    "@ecssc/commitlint-config": "^0.0.4",
    "eslint": "^9.39.2",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.4.2",
    "release-it": "^20.2.1"
  }
}
